# ============================================================
# Backend - Variables de entorno
# Copia este archivo como ".env" y completa los valores.
# ============================================================

# --- Base de datos PostgreSQL ---
# En Render: usa la "Internal Database URL" que te da el servicio de Postgres.
DATABASE_URL=postgres://usuario:password@host:5432/nombre_bd

# --- Alternativa local (si no usas DATABASE_URL) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=tu_password
# DB_NAME=lacasitadpicaron

# --- Servidor ---
PORT=3000

# --- Frontend permitido por CORS ---
# Local: http://localhost:5173
# Producción: https://tu-frontend.onrender.com
# Puedes poner varias separadas por coma.
FRONTEND_URL=http://localhost:5173

# --- JWT ---
# Obligatoria: el servidor NO arranca sin ella.
SECRET_KEY=cambia_esto_por_una_clave_larga_y_aleatoria

# --- Rutas de siembra de datos ---
# Las rutas /api/dev NO tienen autenticación. Ponlo en "true" solo para
# el primer arranque (crear usuarios y datos base) y luego en "false".
ENABLE_DEV_ROUTES=false
