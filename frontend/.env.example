# ============================================================
# Frontend - Variables de entorno (Vite)
# Copia como ".env" para desarrollo local, o configúralas
# en Render (Static Site → Environment) para producción.
# IMPORTANTE: en Vite las variables deben empezar con VITE_.
# ============================================================

# URL base de la API del backend (incluye /api)
VITE_API_URL=http://localhost:3000/api

# URL del servidor de Socket.IO (sin /api)
VITE_SOCKET_URL=http://localhost:3000
